# ===========================
# BuyNest — Root .gitignore
# ===========================

# Node modules
node_modules/
**/node_modules/

# Build outputs
**/dist/
**/build/
**/.next/

# Environment files (NEVER commit secrets!)
**/.env
**/.env.local
**/.env.development.local
**/.env.test.local
**/.env.production.local

# Logs
**/logs/
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Editor/OS files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
.vscode/
.idea/

# TypeScript
*.tsbuildinfo

# Vite
**/.vite/
