{
  "name": "BuyNest Codespace",
  "image": "mcr.microsoft.com/devcontainers/typescript-node:1-20-bullseye",
  "forwardPorts": [5173, 5000],
  "portsAttributes": {
    "5173": {
      "label": "BuyNest Frontend (Client)",
      "onAutoForward": "openBrowser"
    },
    "5000": {
      "label": "BuyNest Backend (API)",
      "onAutoForward": "silent"
    }
  },
  "postCreateCommand": "npm install && cd buynest-backend && npm install && cd ../buynest-frontend && npm install",
  "postStartCommand": "npm run dev"
}
